  {
    "id": 19,
    "name": "RAG: теоретический вопрос с источниками",
    "category": "rag",
    "state": {
      "original_query": "Что такое velocity в Scrum?",
      "query_type": "rag",
      "intent": "general",
      "entities": {},
      "sql_result": null,
      "rag_response": "Velocity — это метрика производительности Scrum-команды, которая измеряет количество story points, завершённых за один спринт. Она используется для планирования будущих спринтов и оценки пропускной способности команды. Velocity рассчитывается как сумма story points всех задач, доведённых до состояния Done в спринте.",
      "rag_sources": [
        "scrum_guide/velocity.md",
        "agile_metrics/team_metrics.md"
      ],
      "validation_result": { "use_sql": false, "use_rag": true, "note": null }
