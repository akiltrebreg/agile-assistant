# vLLM Configuration (main LLM — avibe-gptq-8bit)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# vLLM for text2sql (arctic-7b)
SQL_VLLM_BASE_URL=http://localhost:8001/v1
SQL_VLLM_MODEL=/models/arctic-text2sql-gptq-8bit

# S3 Storage (Yandex Cloud Object Storage) — models + knowledge base
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=quant-models-agile
S3_MODEL_PATH=models/avibe-gptq-8bit
S3_KB_BUCKET=knowledge-base
S3_KB_PATH=knowledge_base
S3_DATA_BUCKET=database-agile
S3_DATA_PATH=data
AWS_ACCESS_KEY_ID=your-yc-key-id
AWS_SECRET_ACCESS_KEY=your-yc-secret-key
AWS_DEFAULT_REGION=ru-central1

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hse_user
POSTGRES_PASSWORD=hse_password
POSTGRES_DB=hse_jira_db

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
 -sI -H 'Accept-Encoding: gzip' \
    http://195.209.218.21/grafana/public/build/9778.aeed2343301c3e5780fc.js | \
    grep -iE 'content-length|content-encoding'
После этого — incognito-окно на http://195.209.218.21/grafana/ (старые несжатые JS в кеше браузера могут застрять). Должны увидеть 4 дашборда в папке "Agile Assistant".
# VSELLM (LLM-as-judge for RAGAS evaluation)
VSELLM_API_KEY=your-vsellm-api-key

# Logging
LOG_LEVEL=INFO

# Monitoring (Prometheus + Grafana, Phase 1)
GRAFANA_PASSWORD=admin

# Langfuse (LLM Tracing, Phase 3)
# Public/Secret keys are generated in the Langfuse UI after first launch:
#   1. open http://localhost:3001 → register admin user
#   2. create project → Settings → API Keys → Create New
#   3. paste the keys here and restart api + celery-worker
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=true

# Langfuse Server (NextAuth + DB encryption)
# Generate strong random values for production: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production

# ── Optional overrides ──
# All RAG/retrieval/reranker parameters have sensible defaults in
# hse_prom_prog/config.py. Override here only when running experiments:
#
# SEARCH_TYPE=hybrid               # dense | sparse | hybrid
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_SPARSE_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSION=256          # Matryoshka truncation
# RERANKER_ENABLED=false
