# ── vLLM (main LLM — avibe-gptq-8bit, GPTQ 8-bit) ──
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=/models/avibe-gptq-8bit
VLLM_API_KEY=EMPTY
VLLM_TEMPERATURE=0.0
VLLM_MAX_TOKENS=2048
VLLM_REPETITION_PENALTY=1.15

# ── vLLM SQL (text2sql — qwen3-8b-awq-4bit, AWQ 4-bit) ──
SQL_VLLM_BASE_URL=http://localhost:8001/v1
SQL_VLLM_MODEL=/models/qwen3-8b-awq-4bit

# ── S3 Storage (Yandex Cloud Object Storage) — модели + база знаний ──
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=quant-models-agile
S3_MODEL_PATH=models/avibe-gptq-8bit
S3_KB_BUCKET=knowledge-base
S3_KB_PATH=knowledge_base
S3_DATA_BUCKET=database-agile
S3_DATA_PATH=data
# Embedding / reranker model snapshots (downloaded on first use, cached locally).
# Default: s3://quant-models-agile/models/multilingual-e5-base/ → /app/models/multilingual-e5-base/
S3_MODELS_BUCKET=quant-models-agile
S3_MODELS_PATH=models
EMBEDDING_MODEL_CACHE_DIR=/app/models
AWS_ACCESS_KEY_ID=your-yc-key-id
AWS_SECRET_ACCESS_KEY=your-yc-secret-key
AWS_DEFAULT_REGION=ru-central1

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hse_user
POSTGRES_PASSWORD=hse_password
POSTGRES_DB=hse_jira_db

# ── Qdrant + Embedding ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=business_docs
EMBEDDING_MODEL=multilingual-e5-base

# ── VSELLM (LLM-as-judge для RAGAS-eval + judge-таска) ──
VSELLM_API_KEY=your-vsellm-api-key
VSELLM_BASE_URL=https://api.vsellm.ru/v1

# LLM-as-a-Judge — async per-response quality scoring через GPT-5.2.
# false → judge-пайплайн полностью отключён, workflow продолжает работать.
JUDGE_ENABLED=true

# ── Logging ──
LOG_LEVEL=INFO

# ── Monitoring (Prometheus + Grafana) ──
GRAFANA_PASSWORD=admin

# ── Langfuse (LLM Tracing) ──
# Public/Secret keys генерируются в Langfuse UI после первого запуска:
#   1. open http://localhost:3001 → register admin user
#   2. create project → Settings → API Keys → Create New
#   3. paste the keys here and restart api + celery-worker
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=true

# Langfuse Server (NextAuth + DB encryption)
# Для prod сгенерировать сильные значения: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production
LANGFUSE_SALT=changeme-in-production
# NEXTAUTH_URL должен совпадать с URL, который пользователь набирает в браузере
# (host:port). По умолчанию http://localhost:3001; для прода переопределить на
# реальный хост (например http://195.209.218.21:3001 или https://<domain>/langfuse).
# LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# ── Optional overrides ──
# Все RAG / retrieval / reranker параметры имеют разумные дефолты в
# agile_assistant/config.py. Переопределять здесь только при экспериментах:
#
# SEARCH_TYPE=hybrid                     # dense | sparse | hybrid (default: dense)
# EMBEDDING_SPARSE_MODEL=BAAI/bge-m3     # пусто = fastembed BM25
# EMBEDDING_DIMENSION=256                # Matryoshka truncation
# RERANKER_ENABLED=false                 # default: true
# GUARDRAIL_ENABLED=false                # default: true
