{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "E2E Latency (p50 / p95 / p99)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(agile_assistant_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(agile_assistant_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(agile_assistant_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "E2E Latency by Query Type (p95)",
      "id": 2,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(agile_assistant_pipeline_duration_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "{{query_type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Throughput (requests/min)",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqpm" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agile_assistant_tasks_total[5m])) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "id": 4,
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agile_assistant_tasks_total{status=\"FAILED\"}[5m])) / clamp_min(sum(rate(agile_assistant_tasks_total[5m])), 1e-9)",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tasks In Progress",
      "id": 5,
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [{ "refId": "A", "expr": "agile_assistant_tasks_in_progress" }]
    },
    {
      "type": "stat",
      "title": "Queue Wait Time (p95)",
      "id": 6,
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(agile_assistant_pipeline_queue_wait_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Task Status Distribution (1h)",
      "id": 7,
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (increase(agile_assistant_tasks_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Celery Queue Length",
      "id": 8,
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "agile_assistant_celery_queue_length",
          "legendFormat": "queue length"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Celery Active Tasks",
      "id": 9,
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        { "refId": "A", "expr": "agile_assistant_celery_active_tasks" }
      ]
    },
    {
      "type": "gauge",
      "title": "Quality Score (1h avg)",
      "id": 10,
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(agile_assistant_judge_weighted_total[1h])"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Quality by Criterion (1h avg)",
      "id": 11,
      "gridPos": { "x": 8, "y": 24, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"agile_correctness\"}[1h])",
          "legendFormat": "agile_correctness"
        },
        {
          "refId": "B",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"practicality\"}[1h])",
          "legendFormat": "practicality"
        },
        {
          "refId": "C",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"context_handling\"}[1h])",
          "legendFormat": "context_handling"
        },
        {
          "refId": "D",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"politeness\"}[1h])",
          "legendFormat": "politeness"
        },
        {
          "refId": "E",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"text_cleanliness\"}[1h])",
          "legendFormat": "text_cleanliness"
        },
        {
          "refId": "F",
          "expr": "avg_over_time(agile_assistant_judge_criterion_score{criterion=\"language_quality\"}[1h])",
          "legendFormat": "language_quality"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agile-assistant", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
